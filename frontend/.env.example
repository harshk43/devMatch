# Frontend environment variables (Vite exposes only VITE_*)

# Local dev with Vite proxy (also requires the backend running on :5000):
#   VITE_API_URL=/api
#
# Local dev hitting the deployed backend directly:
#   VITE_API_URL=https://devmatch-wcpc.onrender.com/api
#
# Production (Vercel) — set this in the Vercel dashboard, NOT in this repo:
#   VITE_API_URL=https://devmatch-wcpc.onrender.com/api

VITE_API_URL=https://devmatch-wcpc.onrender.com/api
